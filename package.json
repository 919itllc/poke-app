{
  "name": "poke-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "allure:e2e": "pwsh -Command \"Remove-Item allure-results -Recurse -Force -ErrorAction SilentlyContinue; playwright test; allure generate ./allure-results -o ./allure-report --clean\"",
    "allure:open": "allure open ./allure-report",
    "heal:report": "npx tsx scripts/heal-report.ts",
    "test:e2e:visual:update": "yarn test:e2e tests/visual.spec.ts --update-snapshots",
    "test:e2e:visual": "playwright test tests/visual.spec.ts",
    "test:e2e:all": "playwright test"
  },
  "dependencies": {
    "@chakra-ui/react": "^2.10.4",
    "@emotion/react": "^11.10.5",
    "@emotion/styled": "^11.10.5",
    "framer-motion": "^9.0.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@langchain/community": "^1.1.29",
    "@langchain/core": "^1.1.49",
    "@langchain/ollama": "^1.2.7",
    "@playwright/test": "^1.58.1",
    "@types/node": "^25.9.3",
    "@types/react": "^18.0.27",
    "@types/react-dom": "^18.0.10",
    "@vitejs/plugin-react": "^3.1.0",
    "allure-playwright": "^3.10.0",
    "langchain": "^1.4.5",
    "tsx": "^4.22.4",
    "typescript": "^5.5.4",
    "vite": "^4.1.0"
  },
  "main": "index.js",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": ""
}